{
  "manifest_version": 3,
  "name": "LinkedIn UK Visa Sponsor Checker",
  "version": "0.1.20",
  "description": "Labels LinkedIn jobs using the official UK visa sponsor list.",
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*"
      ],
      "js": [
        "shared/matcher-core.js",
        "content-script.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "data/sponsor-index.json"
      ],
      "matches": [
        "https://www.linkedin.com/*"
      ]
    }
  ]
}
